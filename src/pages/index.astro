---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 4);

const vlogs = (await getCollection('vlogs'))
  .sort((a, b) => b.data.episode - a.data.episode);
const latestVlog = vlogs[0];

const portfolioItems = (await getCollection('portfolio'))
  .filter(p => p.data.featured);

function fmtDate(d: Date): string {
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', timeZone: 'UTC' });
}

// Cloudflare Turnstile site key (public). Set PUBLIC_TURNSTILE_SITE_KEY in your
// environment for production; the fallback is Cloudflare's "always passes" test key.
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || '1x00000000000000000000AA';
---

<BaseLayout>

<!-- HERO -->
<section class="hero-sec" id="top">
  <div class="hero-bg" role="img" aria-label="Designers seated around a table, talking and working together in a modern office"></div>
  <div class="hero-scrim"></div>
  <div class="wrap">
  <div class="hero">
    <div class="hero-top">
      <span class="label">Human-Centered Design</span>
    </div>
    <h1 class="hero-h">Human by<br />design. <span class="ac">Seamless</span><br />by execution.</h1>
    <div class="hero-split">
      <p class="hero-lede">We turn complex, data-rich enterprise products into experiences people <span class="acw">actually understand</span> — grounded in research, engineered to ship.</p>
      <div class="hero-card">
        <div class="ck">Start here</div>
        <p>Where is complexity slowing your product down?</p>
        <div class="cbtns">
          <a href="#contact" class="btn btn-dark">Start a conversation <span class="arr">→</span></a>
          <a href="/portfolio/" class="btn btn-dark" style="background:transparent;border:1.5px solid rgba(26,17,7,.4);color:var(--on-accent)">See selected work</a>
        </div>
      </div>
    </div>
  </div>
  </div>
</section>

<!-- MARQUEE -->
<div class="marq" aria-hidden="true">
  <div class="marq-track">
    <span>Fintech</span><span>GovTech</span><span>AI-Driven SaaS</span><span>Enterprise Complexity</span><span>Data-Rich Environments</span><span>User Research</span>
    <span>Fintech</span><span>GovTech</span><span>AI-Driven SaaS</span><span>Enterprise Complexity</span><span>Data-Rich Environments</span><span>User Research</span>
  </div>
</div>

<!-- STATS -->
<div class="stats">
  <div class="stat reveal"><div class="n">25+</div><div class="l">Years combined experience in HCI &amp; UX strategy</div></div>
  <div class="stat reveal"><div class="n">100+</div><div class="l">Product &amp; delivery teams coached</div></div>
  <div class="stat reveal"><div class="n">40%</div><div class="l">Average ROI increase across engagements</div></div>
</div>

<!-- SERVICES -->
<section id="services">
  <div class="wrap">
    <div class="sec-head reveal">
      <h2>What we offer</h2>
      <p class="lead">Six disciplines that take the work from first principles to a shipped, measurable outcome.</p>
    </div>
    <div class="svc-grid reveal">
      <div class="svc"><div class="top"><span class="no">01</span><span class="pl">+</span></div><h3>Advising &amp; Coaching</h3><p>Bring clarity to complex transformation challenges through evidence-based research and HCI principles.</p></div>
      <div class="svc"><div class="top"><span class="no">02</span><span class="pl">+</span></div><h3>Application Audits</h3><p>Uncover opportunities and design smarter solutions by combining UX expertise with technical rigor.</p></div>
      <div class="svc"><div class="top"><span class="no">03</span><span class="pl">+</span></div><h3>Collaborative Design</h3><p>Co-create solutions that balance usability with business impact through inclusive design practices.</p></div>
      <div class="svc"><div class="top"><span class="no">04</span><span class="pl">+</span></div><h3>User Research</h3><p>Apply evidence-based methodologies to uncover real user needs and align every decision with goals.</p></div>
      <div class="svc"><div class="top"><span class="no">05</span><span class="pl">+</span></div><h3>Strategy Translation</h3><p>Turn research and design insight into clear, practical strategy that accelerates alignment.</p></div>
      <div class="svc"><div class="top"><span class="no">06</span><span class="pl">+</span></div><h3>Business Impact Analysis</h3><p>Improve the bottom line through data-driven UX that directly lifts conversion and retention.</p></div>
    </div>
  </div>
</section>

<!-- PORTFOLIO / CLIENTS -->
<section id="work" class="clients">
  <div class="wrap">
    <div class="sec-head reveal">
      <h2>Trusted at scale</h2>
      <p class="lead">50+ teams across Canada's largest enterprises and public institutions — where compliance and scale leave no margin for guesswork.</p>
    </div>
    <div class="cli reveal">
      {portfolioItems.map(item => (
        <a href={`/portfolio/${item.slug}/`} class="c">
          <div class="nm">{item.data.client}</div>
        </a>
      ))}
    </div>
    <div style="margin-top:30px"><a href="/portfolio/" class="btn btn-line">View the portfolio <span class="arr">→</span></a></div>
  </div>
</section>

<!-- PROCESS -->
<section id="process">
  <div class="wrap">
    <div class="sec-head reveal">
      <h2>How we work</h2>
      <p class="lead">A collaborative, evidence-based method built to drive alignment and accelerate execution.</p>
    </div>
    <div class="proc reveal">
      <div class="prow"><div class="pn">01</div><h4>Discovery</h4><p>Understand your challenges, goals, and current state through stakeholder interviews and context analysis.</p></div>
      <div class="prow"><div class="pn">02</div><h4>Research &amp; Analysis</h4><p>Apply evidence-based research and HCI principles to uncover needs and surface real opportunities.</p></div>
      <div class="prow"><div class="pn">03</div><h4>Co-Creation</h4><p>Design with your team to balance usability, technical feasibility, and business impact.</p></div>
      <div class="prow"><div class="pn">04</div><h4>Implementation</h4><p>Translate insight into action and coach your team through execution for sustainable success.</p></div>
    </div>
  </div>
</section>

<!-- INSIGHTS -->
<section id="insights">
  <div class="wrap">
    <div class="sec-head reveal">
      <h2>Insights &amp; vlog</h2>
      <p class="lead">Where research, AI, and systems thinking meet practice.</p>
    </div>
    <div class="ins reveal">
      <div class="plist">
        {articles.map(article => (
          <a href={`/articles/${article.slug}/`}>
            <div>
              <div class="tag">{article.data.tag}</div>
              <h4>{article.data.title}</h4>
            </div>
            <div class="dt">{fmtDate(article.data.date)}</div>
          </a>
        ))}
        <div style="margin-top:28px"><a href="/articles/" class="btn btn-line">All articles <span class="arr">→</span></a></div>
      </div>
      {latestVlog && (
        <a href={`/vlogs/${latestVlog.slug}/`} class="vbox">
          <div class="vth"><div class="play"><svg width="22" height="22" viewBox="0 0 24 24" fill="#fff" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg></div></div>
          <div class="vb">
            <div class="tag">Design Vlog · Latest</div>
            <h4>{latestVlog.data.title}</h4>
            <div class="vm">EPISODE {latestVlog.data.episode} · {fmtDate(latestVlog.data.date).toUpperCase()}</div>
          </div>
        </a>
      )}
    </div>
  </div>
</section>

<!-- CTA -->
<section id="contact" class="cta">
  <div class="big-mark" aria-hidden="true"></div>
  <div class="wrap">
    <span class="label">Start a conversation</span>
    <h2>Let's build something people understand.</h2>
    <p>Tell us where complexity is slowing you down. We'll uncover the opportunity, design the smarter solution, and ship experiences that move the bottom line.</p>

    <form id="contactForm" class="cta-form" novalidate>
      <div class="cf-grid">
        <label class="cf-field">
          <span class="cf-lab">Name</span>
          <input type="text" name="name" required autocomplete="name" maxlength="120" />
        </label>
        <label class="cf-field">
          <span class="cf-lab">Email</span>
          <input type="email" name="email" required autocomplete="email" maxlength="200" />
        </label>
      </div>
      <label class="cf-field">
        <span class="cf-lab">Company <em>optional</em></span>
        <input type="text" name="company" autocomplete="organization" maxlength="160" />
      </label>
      <label class="cf-field">
        <span class="cf-lab">Where is complexity slowing you down?</span>
        <textarea name="message" rows="4" required maxlength="4000"></textarea>
      </label>

      <!-- Honeypot: hidden from humans, catches naive bots -->
      <input type="text" name="website" class="cf-hp" tabindex="-1" autocomplete="off" aria-hidden="true" />

      <div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-theme="light"></div>

      <div class="cf-actions">
        <button type="submit" class="btn btn-dark">Send message <span class="arr">→</span></button>
        <a href="mailto:hello@mimicodesignhouse.com" class="cf-alt">or email hello@mimicodesignhouse.com</a>
      </div>

      <p class="cf-status" role="status" aria-live="polite" hidden></p>
    </form>
  </div>
</section>

<script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
<script is:inline>
(function () {
  "use strict";
  const form = document.getElementById("contactForm");
  if (!form) return;
  const statusEl = form.querySelector(".cf-status");
  const btn = form.querySelector("button[type=submit]");

  function setStatus(msg, kind) {
    statusEl.textContent = msg;
    statusEl.hidden = false;
    statusEl.className = "cf-status" + (kind ? " is-" + kind : "");
  }

  form.addEventListener("submit", async function (e) {
    e.preventDefault();

    // Honeypot tripped — pretend success, do nothing.
    if (form.website && form.website.value) { setStatus("Thanks — we'll be in touch.", "ok"); return; }

    if (!form.checkValidity()) { form.reportValidity(); return; }

    const token = (form.querySelector('[name="cf-turnstile-response"]') || {}).value;
    if (!token) { setStatus("Please complete the verification challenge and try again.", "err"); return; }

    btn.disabled = true;
    setStatus("Sending…", "");

    try {
      const res = await fetch("/api/contact", { method: "POST", body: new FormData(form) });
      const data = await res.json().catch(function () { return {}; });
      if (res.ok) {
        form.reset();
        if (window.turnstile) window.turnstile.reset();
        setStatus("Thanks — your message is on its way. We'll reply within a couple of business days.", "ok");
      } else {
        if (window.turnstile) window.turnstile.reset();
        setStatus(data.error || "Something went wrong. Please email us directly at hello@mimicodesignhouse.com.", "err");
      }
    } catch (err) {
      setStatus("Network error. Please email us directly at hello@mimicodesignhouse.com.", "err");
    } finally {
      btn.disabled = false;
    }
  });
})();
</script>

</BaseLayout>
