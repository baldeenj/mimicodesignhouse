---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

function fmtDate(d: Date): string {
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', timeZone: 'UTC' });
}
---

<BaseLayout
  title="Articles — Mimico Design House"
  description="Insights on UX, HCI, AI, and design strategy from the Mimico Design House team."
>
  <div class="wrap">
    <div class="page-hd">
      <h1>Articles</h1>
      <p class="lead">Research, AI, systems thinking, and practice — perspectives from the studio.</p>
    </div>

    <div class="article-list">
      {articles.map(article => (
        <a href={`/articles/${article.slug}/`} class="ac-row">
          <div>
            <div class="tag">{article.data.tag}</div>
            <h2>{article.data.title}</h2>
            {article.data.summary && <p>{article.data.summary}</p>}
          </div>
          <div class="dt">{fmtDate(article.data.date)}</div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
